# Flight price API token — free, from https://www.travelpayouts.com (Tools -> API)
TP_TOKEN=your_travelpayouts_token

# Telegram bot (easiest notifications):
#   1) message @BotFather -> /newbot -> copy the token
#   2) message your new bot once, then visit
#      https://api.telegram.org/bot<token>/getUpdates to read your chat id
TG_BOT_TOKEN=123456:ABC-yourBotToken
TG_CHAT_ID=123456789
