# Flight price API token — free, from https://www.travelpayouts.com (Tools -> API)
# Needed only for `provider: travelpayouts`.
TP_TOKEN=your_travelpayouts_token

# Amadeus Self-Service (real fares, free monthly quota) — needed only for
# `provider: amadeus`. Register at https://developers.amadeus.com to get a
# key + secret. Test and production environments use SEPARATE credentials;
# match amadeus.environment in config.yaml.
AMADEUS_CLIENT_ID=your_amadeus_key
AMADEUS_CLIENT_SECRET=your_amadeus_secret

# Telegram bot (easiest notifications):
#   1) message @BotFather -> /newbot -> copy the token
#   2) message your new bot once, then visit
#      https://api.telegram.org/bot<token>/getUpdates to read your chat id
TG_BOT_TOKEN=123456:ABC-yourBotToken
TG_CHAT_ID=123456789
